{
  "name": "mythos",
  "version": "1.0.0",
  "private": true,
  "description": "Mythology & Folklore Encyclopedia - Research-backed interactive database",
  "packageManager": "pnpm@10.28.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "prepare": "[ -d .git ] && husky || true",
    "start": "turbo start"
  },
  "lint-staged": {
    "apps/web/**/*.{ts,tsx}": [
      "pnpm --filter web exec eslint --fix",
      "prettier --write"
    ],
    "*.{ts,tsx,js,jsx}": [
      "prettier --write"
    ],
    "*.{json,md,yml,yaml,css}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.18",
    "@tailwindcss/typography": "^0.5.19",
    "eslint": "^9.39.4",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.4.2",
    "tailwindcss": "^4.1.18",
    "turbo": "^2.3.3",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.7.2"
  },
  "pnpm": {
    "overrides": {
      "minimatch@<3.1.4": "3.1.4",
      "minimatch@>=5.0.0 <5.1.8": "5.1.8",
      "minimatch@>=9.0.0 <9.0.7": "9.0.7",
      "rollup@>=4.0.0 <4.59.0": "4.59.0",
      "rollup@<2.80.0": "2.80.0",
      "serialize-javascript@<=7.0.2": "7.0.3",
      "ajv@<6.14.0": "6.14.0",
      "ajv@>=7.0.0-alpha.0 <8.18.0": "8.18.0",
      "flatted@<3.4.2": "3.4.2",
      "dompurify@<3.2.6": "3.2.6"
    }
  },
  "license": "MIT"
}
