# Mythos Atlas - Environment Variables
# Copy this file to .env.local and fill in the values

# =============================================================================
# API Configuration
# =============================================================================

# GraphQL API endpoint (optional — only needed if using the Rust backend instead of the built-in route handler)
# NEXT_PUBLIC_GRAPHQL_URL=http://localhost:8080/graphql

# =============================================================================
# AI/LLM Configuration (Optional - for Oracle feature)
# =============================================================================

# Anthropic API key for Claude (Oracle feature)
ANTHROPIC_API_KEY=

# Optional: override default Oracle model (default: claude-sonnet-4-6 — verify in Anthropic docs)
# ANTHROPIC_ORACLE_MODEL=claude-3-5-sonnet-20241022

# OpenAI API (optional — semantic Oracle grounding). Prefer OPENAI_EMBEDDINGS_API_KEY for separation.
# OPENAI_EMBEDDINGS_API_KEY=
# OPENAI_API_KEY=

# Upstash Redis (optional — shared rate limits for Oracle across serverless instances)
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# Enable the Oracle AI chat button (set to "true" to show the floating Oracle button)
NEXT_PUBLIC_ORACLE_ENABLED=

# PWA install prompt (beforeinstallprompt). Requires a working SW strategy; off by default.
# NEXT_PUBLIC_PWA_INSTALL_PROMPT=true

# =============================================================================
# Error Tracking (Sentry)
# =============================================================================

# Sentry DSN for error tracking (get from sentry.io)
NEXT_PUBLIC_SENTRY_DSN=

# Sentry organization slug
SENTRY_ORG=

# Sentry project slug
SENTRY_PROJECT=

# Sentry auth token (for source map uploads in CI)
SENTRY_AUTH_TOKEN=

# =============================================================================
# Analytics (Optional)
# =============================================================================

# Google Analytics measurement ID
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Vercel Analytics
NEXT_PUBLIC_VERCEL_ANALYTICS_ID=
