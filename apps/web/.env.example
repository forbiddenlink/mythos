# Mythos Atlas - Environment Variables
# Copy this file to .env.local and fill in the values

# =============================================================================
# API Configuration
# =============================================================================

# GraphQL API endpoint (Rust backend)
NEXT_PUBLIC_GRAPHQL_URL=http://localhost:8080/graphql

# =============================================================================
# AI/LLM Configuration (Optional - for Oracle feature)
# =============================================================================

# Anthropic API key for Claude (Oracle feature)
ANTHROPIC_API_KEY=

# =============================================================================
# Error Tracking (Sentry)
# =============================================================================

# Sentry DSN for error tracking (get from sentry.io)
NEXT_PUBLIC_SENTRY_DSN=

# Sentry organization slug
SENTRY_ORG=

# Sentry project slug
SENTRY_PROJECT=

# Sentry auth token (for source map uploads in CI)
SENTRY_AUTH_TOKEN=

# =============================================================================
# Analytics (Optional)
# =============================================================================

# Google Analytics measurement ID
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Vercel Analytics
NEXT_PUBLIC_VERCEL_ANALYTICS_ID=
